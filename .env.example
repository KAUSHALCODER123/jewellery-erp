# Copy to `.env` and fill in. Never commit the real .env.

# Live metal-rate sync (Settings -> Sync Live Rate). Required for live rates;
# when unset, the app returns a clear error and the shop enters rates manually.
# Get a key from the APISED gold provider.
GOLD_API_KEY=

# Optional: override the rate provider endpoint (defaults to the APISED gold API).
# GOLD_API_URL=

# JWT signing secret for auth tokens. Defaults to an insecure development
# constant if unset — set a strong random value for any non-local deployment.
# JWT_SECRET=
