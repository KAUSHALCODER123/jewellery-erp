{
  "name": "jewellery-erp",
  "engines": {
    "node": ">=20 <21"
  },
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": "dist/server.cjs",
  "pkg": {
    "assets": [
      "drizzle/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "node_modules/@serialport/bindings-cpp/prebuilds/**/*"
    ]
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "predev:backend": "node scripts/ensure-better-sqlite3.cjs",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:typecheck": "tsc --noEmit",
    "rebuild:sqlite": "npm rebuild better-sqlite3",
    "rebuild:sqlite:pkg": "node scripts/rebuild-sqlite-for-pkg.js",
    "build:backend": "node scripts/build-sidecar.js --bundle-only",
    "rename:sidecar": "node scripts/build-sidecar.js --rename-only",
    "build:frontend": "vite build",
    "preview:frontend": "vite preview --host 127.0.0.1 --port 5173",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/api --runInBand --forceExit",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "test:desktop": "node tests/desktop/desktop-smoke.mjs",
    "test:desktop:features": "node tests/desktop/desktop-features.mjs",
    "build:sidecar": "node scripts/build-sidecar-node.cjs",
    "build:sidecar:pkg": "npm run rebuild:sqlite:pkg && npm run build:backend && pkg . --targets node18-win-x64,node18-macos-x64 --out-path src-tauri/binaries && npm run rename:sidecar",
    "build:desktop": "npm run build && npm run build:sidecar && tauri build"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "multer": "^2.1.1",
    "pdfmake": "^0.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "serialport": "^13.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.30.2",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "pkg": "^5.8.1",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
